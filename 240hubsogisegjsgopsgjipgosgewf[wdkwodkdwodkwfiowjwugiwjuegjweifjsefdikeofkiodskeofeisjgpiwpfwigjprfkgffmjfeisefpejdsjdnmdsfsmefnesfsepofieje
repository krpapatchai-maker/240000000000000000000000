-- ระบบกดเล่นเพลง (อิงตามโค้ด Cobalt ที่ให้มา)
playButton.MouseButton1Click:Connect(function()
    local musicId = idTextBox.Text
    
    if musicId ~= "" then
        pcall(function()
            local Event = game:GetService("ReplicatedStorage").RE["1Too1l"]
            Event:InvokeServer(
                "PickingTools",
                "Boombox"
            )
            
            task.wait(0.4)
            
            -- ส่งคำสั่งเปิดเพลงผ่าน PlayerToolEvent
            local musicEvent = game:GetService("ReplicatedStorage").RE:FindFirstChild("PlayerToolEvent")
            if musicEvent then
                local payload = musicId .. "&" .. musicId .. "&กันดัก240ค้าบบไอต้าววววววว"
                musicEvent:FireServer("ToolMusicText", payload)
            end
        end)
    else
        warn("กรุณากรอกไอดีเพลงก่อน!")
    end
end)

-- ระบบลากหน้าต่าง UI (รองรับทั้งเมาส์และมือถือ)
local userInputService = game:GetService("UserInputService")
local dragging, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)
